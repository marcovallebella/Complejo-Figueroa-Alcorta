# --- Frontend (Vite) — estas SÍ se exponen en el navegador ---

# Supabase: Settings > API en tu proyecto
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key_publica

# MercadoPago: si en el futuro usás el SDK de checkout embebido en frontend
VITE_MP_PUBLIC_KEY=tu_public_key_de_mercadopago

# --- Backend (server.js / rutas /api) — NUNCA exponer en frontend ---

# MercadoPago: Tus integraciones > Credenciales (usar TEST para pruebas)
MP_ACCESS_TOKEN=tu_access_token_de_mercadopago

# Supabase: Settings > API > service_role (clave secreta, solo backend)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# URL pública donde está deployado el sitio (sin / al final)
SITE_URL=https://tudominio.com

# Puerto del servidor Node. En Hostinger lo asigna la plataforma sola;
# en local, por defecto usa 3000 si no se define.
# PORT=3000

# Resend (https://resend.com) — envío automático de recibos por mail.
# Crear cuenta gratis (hasta 3000 mails/mes), copiar la API key desde
# el dashboard (API Keys > Create API Key).
RESEND_API_KEY=tu_resend_api_key

# Opcional. Remitente de los mails. Si no se define, usa el dominio de
# pruebas de Resend (onboarding@resend.dev), que funciona sin verificar
# nada pero puede caer en spam. Para producción, verificá tu propio
# dominio en Resend (Domains > Add Domain) y usá un mail de ese dominio.
# EMAIL_FROM=Complejo Figueroa Alcorta <recibos@tudominio.com>
